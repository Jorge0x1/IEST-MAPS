// escaleras que conectan piso 1 con piso 2
// clave: celda en piso 1, valor: celda equivalente en piso 2
// permite el pathfinding cruzar entre pisos
export const conexionesInterPiso: Record<number, number> = {
  65: 1065,
  1065: 65,
  258: 1258,
  1258: 258,
  408: 1408,
  1408: 408,
  575: 1575,
  1575: 575,
  588: 1588,
  707: 1707,
  1707: 707,
  719: 1719,
  1719: 719,
}

// union de todas las celdas disponibles en ambos pisos
// facilita verificacion rapida si una celda es accesible
export const todasLasCeldas = new Set([...celdasDisponiblesP1, ...celdasDisponiblesP2])

// encuentra a que piso pertenece una celda
// retorna 1, 2 o null si la celda no existe
export function getFloorByCell(cellId: number): 1 | 2 | null {
  if (celdasDisponiblesP1.has(cellId)) return 1
  if (celdasDisponiblesP2.has(cellId)) return 2
  return null
}

// obtiene el archivo de imagen SVG para el piso
// piso 1: Mapa.svg, piso 2: MapaP2.svg
export function getFloorImage(floor: 1 | 2): string {
  return floor === 1 ? '/assets/maps/Mapa.svg' : '/assets/maps/MapaP2.svg'
}

// calcula el offset numerico para las celdas de un piso
// piso 1: offset 0 (celdas 1-900)
// piso 2: offset 1000 (celdas 1001-1900)
export function getFloorOffset(floor: 1 | 2): number {
  return floor === 2 ? 1000 : 0
}
