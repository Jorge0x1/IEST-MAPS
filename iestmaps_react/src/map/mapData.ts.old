// datos del mapa: grilla, celdas disponibles, escaleras, etc

// dimensiones de la grilla del mapa (30x30 celdas)
export const FIXED_COLS = 30
export const FIXED_ROWS = 30
// total de celdas por piso (900)
export const CELLS_PER_FLOOR = FIXED_COLS * FIXED_ROWS

